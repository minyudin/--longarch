# ============================================================
#  韶山稻梦田园智慧大棚 — 生产环境变量模板
#  复制为 /opt/longarch/.env 并填入真实值
# ============================================================

# ---------- MySQL ----------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=longarch
DB_USERNAME=longarch
DB_PASSWORD=

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- MQTT (Mosquitto) ----------
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_USERNAME=longarch
MQTT_PASSWORD=longarch123
MQTT_CMD_PREFIX=longarch/device/command/
MQTT_CB_TOPIC=longarch/device/callback/#
MQTT_TELE_PREFIX=longarch/device/telemetry/
MQTT_HB_PREFIX=longarch/device/heartbeat/

# ---------- 大屏 Dashboard ----------
DASHBOARD_TOKEN=

# ---------- 微信小程序 ----------
WX_APP_ID=
WX_APP_SECRET=

# ---------- 智谱 AI ----------
ZHIPU_API_KEY=

# ---------- SRS 流媒体 ----------
SRS_API_BASE=http://localhost:1985
SRS_RTMP_BASE=rtmp://localhost:1935
SRS_HTTP_FLV_BASE=http://localhost:8880
SRS_HLS_BASE=http://localhost:8880
